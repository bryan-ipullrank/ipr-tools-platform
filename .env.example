# Copy to .env and fill in real values. Never commit .env.

# Flask session signing key. Generate a stable random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Google OAuth 2.0 client credentials (Google Cloud Console > Credentials)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Only Google accounts on this domain may sign in.
ALLOWED_EMAIL_DOMAIN=ipullrank.com

# Comma-separated emails that are auto-promoted to admin on login (bootstrap).
# Admins can edit any tool and manage roles; after bootstrap, admins can also
# promote/demote others from the /admin/users page.
IDP_ADMINS=bryan@ipullrank.com

# Database connection string. Leave unset to use a local SQLite file
# (idp.db in the project root). To use MySQL/Postgres later, set e.g.:
#   mysql+pymysql://user:pass@host/dbname
#   postgresql+psycopg://user:pass@host/dbname
# DATABASE_URL=

# --- Claude Code plugin marketplace (Phase 3) -------------------------------
# Shared token that gates GET /marketplace.json over HTTP Basic. Developers
# register the marketplace as:
#   /plugin marketplace add https://you:MARKETPLACE_TOKEN@<host>/marketplace.json
# The endpoint fails CLOSED: 401 on a wrong token, 503 if this is left unset, so
# leaving it blank keeps the internal plugin list private rather than public.
# Generate a strong value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MARKETPLACE_TOKEN=

# Optional marketplace metadata (sensible defaults are used if unset).
# MARKETPLACE_NAME is the id devs install against: `<plugin>@<MARKETPLACE_NAME>`.
# MARKETPLACE_NAME=ipr-tools
# MARKETPLACE_OWNER_NAME=iPullRank Engineering
# MARKETPLACE_DESCRIPTION=Internal SEO & engineering plugins

# LOCAL DEV ONLY. Lets OAuth run over http://localhost.
# Do NOT set this on PythonAnywhere — it serves real HTTPS.
OAUTHLIB_INSECURE_TRANSPORT=1
