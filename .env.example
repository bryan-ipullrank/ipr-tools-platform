# Copy to .env and fill in real values. Never commit .env.

# Flask session signing key. Generate a stable random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Google OAuth 2.0 client credentials (Google Cloud Console > Credentials)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Only Google accounts on this domain may sign in.
ALLOWED_EMAIL_DOMAIN=ipullrank.com

# Comma-separated emails that are auto-promoted to admin on login (bootstrap).
# Admins can edit any tool and manage roles; after bootstrap, admins can also
# promote/demote others from the /admin/users page.
IDP_ADMINS=bryan@ipullrank.com

# Database connection string. Leave unset to use a local SQLite file
# (idp.db in the project root). To use MySQL/Postgres later, set e.g.:
#   mysql+pymysql://user:pass@host/dbname
#   postgresql+psycopg://user:pass@host/dbname
# DATABASE_URL=

# LOCAL DEV ONLY. Lets OAuth run over http://localhost.
# Do NOT set this on PythonAnywhere — it serves real HTTPS.
OAUTHLIB_INSECURE_TRANSPORT=1
