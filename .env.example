# Copy to .env and fill in real values. Never commit .env.

# Flask session signing key. Generate a stable random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Google OAuth 2.0 client credentials (Google Cloud Console > Credentials)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Only Google accounts on this domain may sign in.
ALLOWED_EMAIL_DOMAIN=ipullrank.com

# LOCAL DEV ONLY. Lets OAuth run over http://localhost.
# Do NOT set this on PythonAnywhere — it serves real HTTPS.
OAUTHLIB_INSECURE_TRANSPORT=1
